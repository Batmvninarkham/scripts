sysrc nginx_enable="YES"  
service nginx restart
echo "this is a basic setup please edit the nginx config file eg sudo vim  /usr/local/etc/nginx/nginx.conf"
}
fuzzy(){
   echo "installling fzf and bat ..."
for cmd in fzf bat ;do
   command -v "$cmd" >dev/null 2>&1 || pkg install -y "$cmd"
done
cat >> ~/.zshrc <<'EOF'
alias nf='fzf -m --preview="bat --color=always {}" --bind "enter:become(vim {})"'
EOF
source ~/.zshrc
}

